NEXT_PUBLIC_DEFAULT_LOCALE=ru
NEXT_PUBLIC_SUPPORTED_LOCALES=ru,uk,en
NEXT_PUBLIC_CMS_URL=http://localhost:1337

# Strapi CMS
CMS_HOST=0.0.0.0
CMS_PORT=1337

# Supabase (https://supabase.com/dashboard/project/<ref>/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-jwt>
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>

# ---------------------------------------------------------------------------
# Vercel — add these in: vercel.com → Project → Settings → Environment Variables
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL        → same as above
# NEXT_PUBLIC_SUPABASE_ANON_KEY   → same as above
# SUPABASE_SERVICE_ROLE_KEY       → same as above
# NEXT_PUBLIC_DEFAULT_LOCALE      → ru
# NEXT_PUBLIC_SUPPORTED_LOCALES   → ru,uk,en
